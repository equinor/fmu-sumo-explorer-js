{
  "name": "@equinor/fmu-sumo-explorer",
  "version": "1.2.0",
  "description": "Package for working with FMU data stored in Sumo.",
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./*": "./src/*"
  },
  "files": [
    "src/**/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "mocha tests/test-explorer",
    "demo": "node --experimental-fetch src/demo.js",
    "lint": "node node_modules/.bin/eslint src",
    "docs": "./node_modules/jsdoc/jsdoc.js -r src -d docs",
    "prepublishOnly": "node -e \"console.log('Packing for publish')\""
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/identity-cache-persistence": "^1.3.0",
    "axios": "^1.15.0",
    "@azure/msal-node": "^5.1.5",
    "axios-retry": "^4.5.0",
    "lru-cache": "^11.2.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.5"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "^7.0.5",
      "diff": "^8.0.4"
    }
  }
}
